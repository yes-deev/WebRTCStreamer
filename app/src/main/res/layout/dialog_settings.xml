<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvSettingsDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_description"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <!-- VPS Server IP Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilStreamUrl"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="@string/stream_url_hint"
        app:endIconMode="clear_text"
        app:startIconDrawable="@drawable/ic_settings">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etStreamUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:maxLines="1"
            android:singleLine="true" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/instances_title"
        android:textAppearance="?attr/textAppearanceTitleSmall"
        android:textColor="?attr/colorPrimary" />

    <!-- Active Android 13 Cloud Instance Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardInstance1"
        style="@style/Widget.Material3.CardView.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorPrimary"
        app:strokeWidth="2dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@id/btnConnectInstance1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/instance_android13"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/instance_status_online"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="#4CAF50" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConnectInstance1"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="@string/btn_connect" />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Secondary Android 13 Instance Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardInstance2"
        style="@style/Widget.Material3.CardView.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutline">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@id/btnConnectInstance2"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/instance_android13_2"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/instance_status_online"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="#4CAF50" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConnectInstance2"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="@string/btn_connect" />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Exit / Disconnect Stream Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDisconnectDialog"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/btn_exit_stream"
        android:textColor="#FF5252"
        app:strokeColor="#FF5252" />

</LinearLayout>
